---
// Shared top navigation — fixed bar + full-screen mobile drawer + services dropdown
// + language switcher. Interactivity is a tiny vanilla island; no framework runtime.
import { services, type Lang } from '../i18n/ui';
import { t, localizePath, stripLocale } from '../i18n/utils';

const { lang = 'en' } = Astro.props as { lang?: Lang };

const base = stripLocale(Astro.url.pathname);
const isHome = base === '/';
const L = (path: string) => localizePath(path, lang);

const otherLang: Lang = lang === 'es' ? 'en' : 'es';
const switchHref = localizePath(base, otherLang);

const navServices = services.map((s) => ({
  num: s.num,
  href: L(s.path),
  label: lang === 'es' ? s.es : s.en,
}));
---

<nav class="nav" data-nav>
  <a href={L('/')} class="logo">
    <span class="seg"><span class="cap">W</span><span class="tail">ork</span></span>
    <span class="sep">·</span>
    <span class="seg"><span class="cap">O</span><span class="tail">f</span></span>
    <span class="sep">·</span>
    <span class="seg"><span class="cap">A</span><span class="tail">rt</span></span>
    <span class="diamond" aria-hidden="true"></span>
  </a>
  <div class="nav-links">
    <div class="nav-svc" data-svc>
      <button
        type="button"
        class="nav-svc-trigger"
        aria-haspopup="true"
        aria-expanded="false"
        data-svc-trigger
      >
        {t(lang, 'nav.services')} <span class="chev" aria-hidden="true">▾</span>
      </button>
      <div class="nav-svc-menu" role="menu">
        {
          navServices.map((s) => (
            <a href={s.href} role="menuitem" class="nav-svc-item">
              <span class="num">{s.num}</span>
              <span class="lbl">{s.label}</span>
              <span class="arr">→</span>
            </a>
          ))
        }
      </div>
    </div>
    <a href={L('/about')}>{t(lang, 'nav.about')}</a>
    <a href={L('/contact#inquiry-form')}>{t(lang, 'nav.contact')}</a>
  </div>
  <div class="nav-right">
    <a href={switchHref} class="nav-lang" aria-label={t(lang, 'lang.switchTo')} title={t(lang, 'lang.switchTo')}>
      {t(lang, 'lang.label')}
    </a>
    {
      !isHome && (
        <a href={L('/')} class="nav-home" aria-label={t(lang, 'nav.home')} title={t(lang, 'nav.home')}>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M 3 11 L 12 3 L 21 11" />
            <path d="M 5 10 L 5 21 L 19 21 L 19 10" />
            <path d="M 10 21 L 10 15 L 14 15 L 14 21" />
          </svg>
        </a>
      )
    }
    <a href={L('/contact')} class="btn btn-solid nav-book">
      {t(lang, 'nav.book')} <span class="arr">→</span>
    </a>
    <button class="nav-burger" aria-label={t(lang, 'nav.openMenu')} aria-expanded="false" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="nav-drawer" aria-hidden="true" data-drawer>
  <div class="nav-drawer-inner">
    <div class="drawer-group" data-drawer-svc>
      <button
        type="button"
        class="drawer-svc-toggle"
        data-drawer-svc-toggle
        aria-expanded="false"
        aria-controls="drawer-svc-list"
      >
        {t(lang, 'nav.servicesGroup')}
        <span class="drawer-chev" aria-hidden="true">▾</span>
      </button>
      <div class="drawer-svc-list" id="drawer-svc-list">
        {
          navServices.map((s) => (
            <a href={s.href} class="drawer-sub">
              <span class="num">{s.num}</span>
              {s.label}
            </a>
          ))
        }
      </div>
    </div>
    <a href={L('/')}>{t(lang, 'nav.home')}</a>
    <a href={L('/about')}>{t(lang, 'nav.about')}</a>
    <a href={L('/contact#inquiry-form')}>{t(lang, 'nav.contact')}</a>
    <a href={switchHref} class="drawer-lang">{t(lang, 'lang.switchTo')}</a>
    <div class="nav-drawer-foot">
      <a href={L('/contact')} class="btn btn-solid">
        {t(lang, 'nav.book')} <span class="arr">→</span>
      </a>
    </div>
  </div>
</div>

<style>
  .nav-lang {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--fg-dim);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 7px 12px;
    line-height: 1;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .nav-lang:hover {
    color: var(--fg);
    border-color: var(--fg-dim);
  }
  .drawer-lang {
    color: var(--fg-dim) !important;
  }
  @media (max-width: 720px) {
    /* Keep EN↔ES one tap away on the bar (compact pill). */
    .nav-right .nav-lang {
      padding: 9px 10px;
      font-size: 10px;
      letter-spacing: 0.12em;
      line-height: 1;
    }
  }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  const logo = nav?.querySelector<HTMLElement>('.logo');
  const burger = document.querySelector<HTMLButtonElement>('[data-burger]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');
  const svc = document.querySelector<HTMLElement>('[data-svc]');
  const svcTrigger = document.querySelector<HTMLButtonElement>('[data-svc-trigger]');
  const drawerSvc = document.querySelector<HTMLElement>('[data-drawer-svc]');
  const drawerSvcToggle = document.querySelector<HTMLButtonElement>('[data-drawer-svc-toggle]');

  // Scroll state — wordmark expands to "Work · Of · Art ◆" away from the top.
  const onScroll = () => {
    const scrolled = window.scrollY > 30;
    nav?.classList.toggle('scrolled', scrolled);
    logo?.classList.toggle('peek', scrolled);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile drawer.
  const setDrawer = (open: boolean) => {
    drawer?.classList.toggle('open', open);
    burger?.classList.toggle('open', open);
    burger?.setAttribute('aria-expanded', String(open));
    drawer?.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
    // Reset the services accordion to collapsed each time the drawer closes.
    if (!open) {
      drawerSvc?.classList.remove('open');
      drawerSvcToggle?.setAttribute('aria-expanded', 'false');
    }
  };
  burger?.addEventListener('click', () => setDrawer(!drawer?.classList.contains('open')));
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setDrawer(false)));

  // Drawer services accordion — collapsed by default, tap the row to expand.
  drawerSvcToggle?.addEventListener('click', () => {
    const open = !drawerSvc?.classList.contains('open');
    drawerSvc?.classList.toggle('open', open);
    drawerSvcToggle.setAttribute('aria-expanded', String(open));
  });

  // Services dropdown.
  const setSvc = (open: boolean) => {
    svc?.classList.toggle('open', open);
    svcTrigger?.setAttribute('aria-expanded', String(open));
  };
  svcTrigger?.addEventListener('click', () => setSvc(!svc?.classList.contains('open')));
  svc?.querySelectorAll('.nav-svc-item').forEach((a) => a.addEventListener('click', () => setSvc(false)));
  // Desktop (fine pointer): open the dropdown on hover.
  if (svc && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    svc.addEventListener('mouseenter', () => setSvc(true));
    svc.addEventListener('mouseleave', () => setSvc(false));
  }
  document.addEventListener('mousedown', (e) => {
    if (svc?.classList.contains('open') && !svc.contains(e.target as Node)) setSvc(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setSvc(false);
  });
</script>
