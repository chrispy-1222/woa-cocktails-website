---
// MobileBarCartLanding — every section of the paid Mobile Bar Cart landing
// page, rendered from a locale content object so EN and ES stay structurally
// identical. Ported from woa-lp-cart.jsx (React) → static Astro markup. The
// tracking surface + deferred Calendly/Tally loaders live in LandingLayout.
import Pic from './Pic.astro';
import Footer from './Footer.astro';
import CookieConsent from './CookieConsent.astro';
import { localizePath } from '../i18n/utils';
import type { LpContent, Lang } from '../i18n/lp-cart';
import heroCane from '../assets/img/mb-wedding-cane.jpg';
import heroPuma from '../assets/img/mb-hero-puma.webp';

export interface Props {
  lang: Lang;
  content: LpContent;
}

const { lang, content: c } = Astro.props;
const TEL = 'tel:+12159390476';
const callAria = lang === 'es' ? 'Llamar a WOA' : 'Call WOA';
const homeHref = localizePath('/', lang);
---

<div class="lp">
  {/* ── Simplified header: animated WOA logo + ONE cta ── */}
  <nav class="lp-nav" data-nav>
    <a href={homeHref} class="logo" aria-label="WOA Cocktails — home">
      <span class="seg"><span class="cap">W</span><span class="tail">ork</span></span>
      <span class="sep">·</span>
      <span class="seg"><span class="cap">O</span><span class="tail">f</span></span>
      <span class="sep">·</span>
      <span class="seg"><span class="cap">A</span><span class="tail">rt</span></span>
      <span class="diamond" aria-hidden="true"></span>
    </a>
    <a href="#book" class="btn btn-solid lp-nav-cta" data-cta="nav">
      {c.cta} <span class="arr">→</span>
    </a>
  </nav>

  <main>
    {/* ── Hero — the cart is the hero. LCP = the cart photo. ── */}
    <section class="lp-hero" id="top">
      <div class="lp-hero-bg">
        <Pic src={heroCane} alt={c.hero.bgAlt} kind="hero" priority />
      </div>
      <div class="lp-hero-inner">
        <div class="lp-hero-eyebrow">
          <span class="dot" aria-hidden="true"></span>
          <span class="eyebrow">{c.hero.eyebrow}</span>
        </div>

        <h1>
          {c.hero.h1Line1}<br />{c.hero.h1Line2Lead}<em>{c.hero.h1Emph}</em>
        </h1>

        <p class="lp-hero-sub" set:html={c.hero.sub} />

        {c.offerActive && (
          <div class="lp-offer-pill">
            <span class="tag">{c.hero.pillTag}</span>
            <span class="txt">{c.hero.pillLead}<b>{c.hero.pillEmph}</b>{c.hero.pillTail}</span>
          </div>
        )}

        <div class="lp-hero-cta">
          <a href="#book" class="btn btn-solid" data-cta="hero">
            {c.cta} <span class="arr">→</span>
          </a>
          <a href={TEL} class="btn btn-ghost" data-cta="hero-call">{c.hero.call}</a>
        </div>

        <div class="lp-hero-area">
          {c.hero.area.map((chip, i) => (
            <>
              <span set:html={chip} />
              {i < c.hero.area.length - 1 && <span class="sep">◆</span>}
            </>
          ))}
        </div>
      </div>
    </section>

    {/* ── Offer module (SWAPPABLE) ── */}
    {c.offerActive && (
      <section class="lp-offer" id="offer" aria-label="Current offer">
        <div class="wrap">
          <div class="lp-offer-inner">
            <div>
              <span class="eyebrow amber">{c.offer.eyebrow}</span>
              <div class="lp-offer-free" style="margin-top:14px">
                {c.offer.free1}<br /><em>{c.offer.freeEmph}</em>
              </div>
              <p class="lp-offer-lead" set:html={c.offer.lead} />
              <a href="#book" class="btn btn-solid lp-offer-cta" data-cta="offer">
                {c.cta} <span class="arr">→</span>
              </a>
            </div>
            <div>
              <ul class="lp-offer-terms">
                {c.offer.terms.map((t) => (
                  <li>
                    <span class="n">{t.n}</span>
                    <span class="t">{t.t}<span>{t.sub}</span></span>
                  </li>
                ))}
              </ul>
              <p class="lp-offer-fine">{c.offer.fine}</p>
            </div>
          </div>
        </div>
      </section>
    )}

    {/* ── What you get ── */}
    <section class="lp-section" id="experience">
      <div class="wrap">
        <div class="lp-head">
          <div class="ix">{c.get.ix}</div>
          <h2>{c.get.h2Lead}<span class="it">{c.get.h2It}</span></h2>
          <p>{c.get.intro}</p>
        </div>
        <div class="lp-get-grid">
          <figure class="lp-get-photo">
            <Pic src={heroPuma} alt={c.get.photoAlt} kind="portrait" />
            <figcaption>{c.get.photoCap}</figcaption>
          </figure>
          <div>
            <div class="lp-feats">
              {c.get.features.map((f) => (
                <div class="lp-feat">
                  <span class="n">{f.n}</span>
                  <div>
                    <h3 set:html={f.h} />
                    <p set:html={f.p} />
                  </div>
                </div>
              ))}
            </div>
            <div class="lp-price">
              <div class="lp-price-main">
                <span class="from">{c.get.priceFrom}</span>
                <b>{c.get.priceAmount}</b>
              </div>
              <p set:html={c.get.priceNote} />
            </div>
            <div class="lp-occasions">
              {c.get.occasions.map((o) => (
                <span><b>·</b> {o}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Credibility ── */}
    <section class="lp-section lp-cred" id="why">
      <div class="wrap">
        <div class="lp-head">
          <div class="ix">{c.cred.ix}</div>
          <h2>{c.cred.h2Lead}<span class="it">{c.cred.h2It}</span></h2>
          <p>{c.cred.intro}</p>
        </div>

        <div class="lp-stats">
          {c.cred.stats.map((s) => (
            <div class="lp-stat"><b>{s.b}</b><span>{s.label}</span></div>
          ))}
        </div>

        <div class="lp-testi-row" style="margin-top:0">
          {c.cred.testi.map((t) => (
            <article class="lp-testi">
              <div class="stars">★ ★ ★ ★ ★</div>
              <div class="body">"{t.body}"</div>
              <div class="who"><b>{t.who}</b>{t.role}</div>
            </article>
          ))}
        </div>

        <div class="lp-press">
          <span class="amb">{c.cred.pressLabel}</span>
          {c.cred.press.map((p, i) => (
            <>
              <span>{p}</span>
              {i < c.cred.press.length - 1 && <span>·</span>}
            </>
          ))}
        </div>
      </div>
    </section>

    {/* ── How it works ── */}
    <section class="lp-section" id="how">
      <div class="wrap">
        <div class="lp-head">
          <div class="ix">{c.how.ix}</div>
          <h2>{c.how.h2Lead}<span class="it">{c.how.h2It}</span></h2>
        </div>
        <div class="lp-steps">
          {c.how.steps.map((s) => (
            <div class="lp-step">
              <span class="n">— {s.n}</span>
              <h3 set:html={s.h} />
              <p>{s.p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Conversion block — Tally + Calendly + click-to-call ── */}
    <section class="lp-section lp-book" id="book">
      <div class="wrap">
        <div class="lp-head">
          <div class="ix">{c.book.ix}</div>
          <h2>{c.book.h2Lead}<span class="it">{c.book.h2It}</span></h2>
          <p>{c.book.intro}</p>
        </div>

        <div class="lp-book-grid">
          {/* Tally — request a quote (src injected by LandingLayout, with gclid) */}
          <div class="lp-panel">
            <div class="lp-panel-head">
              <span class="mark" aria-hidden="true">◆</span>
              <span>{c.book.quoteHead}</span>
              <span class="meta">{c.book.quoteMeta}</span>
            </div>
            <div class="lp-form-surface">
              <iframe
                loading="lazy"
                width="100%"
                height="1100"
                frameborder="0"
                marginheight="0"
                marginwidth="0"
                title={c.book.tallyTitle}
                class="lp-tally"></iframe>
            </div>
            <div class="lp-panel-foot">
              <span set:html={c.book.quoteFoot} />
              <span set:html={c.book.quoteReply} />
            </div>
          </div>

          {/* Calendly — book a call (inline widget injected by LandingLayout) */}
          <div class="lp-panel">
            <div class="lp-panel-head">
              <span class="mark" aria-hidden="true">◆</span>
              <span>{c.book.callHead}</span>
              <span class="meta">{c.book.callMeta}</span>
            </div>
            <div class="lp-calendly" data-embed-calendly style="min-width:280px;height:660px"></div>
            <div class="lp-panel-foot">
              <span>{c.book.callFoot}</span>
              <span class="pwby">{c.book.poweredBy} <b>Calendly</b></span>
            </div>
          </div>
        </div>

        {/* click-to-call — secondary */}
        <div class="lp-call-row">
          <div class="lhs">
            <span class="eyebrow dim">{c.book.callRowEyebrow}</span>
            <a href={TEL} class="num" data-cta="call">{c.book.callNumber} <small>{c.book.callNumberSub}</small></a>
          </div>
          <a href={TEL} class="btn btn-ghost" data-cta="call">{c.book.callTap}</a>
        </div>
      </div>
    </section>

    {/* ── Service area + brief FAQ ── */}
    <section class="lp-section" id="area">
      <div class="wrap">
        <div class="lp-area-grid">
          <div>
            <div class="lp-head">
              <div class="ix">{c.area.ix}</div>
              <h2>{c.area.h2Lead}<span class="it">{c.area.h2It}</span></h2>
              <p>{c.area.intro}</p>
            </div>
            <div class="lp-counties">
              {c.area.counties.map((co) => (
                <div class="lp-county"><b>{co.name}</b><span>{co.areas}</span></div>
              ))}
            </div>
          </div>
          <div>
            <div class="eyebrow" style="margin-bottom:12px">{c.area.faqEyebrow}</div>
            <div class="lp-faq">
              {c.area.faq.map((f, i) => (
                <details open={i === 0}>
                  <summary>{f.q}</summary>
                  <div class="ans">{f.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  {/* ── Shared site footer (same as the rest of the site) ── */}
  <Footer lang={lang} />

  {/* ── Sticky mobile CTA ── */}
  <div class="lp-sticky">
    <a href="#book" class="btn btn-solid" data-cta="sticky">{c.cta} →</a>
    <a href={TEL} class="call" aria-label={callAria} data-cta="sticky-call">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
      </svg>
    </a>
  </div>
</div>

{/* Cookie consent — same banner as the rest of the site (tracking embeds + GTM). */}
<CookieConsent lang={lang} />
