---
// Thin wrapper around astro:assets <Image>. Renders a single optimized <img>
// (responsive srcset + WebP + intrinsic width/height → fixes oversized mobile
// downloads, unsized-images and CLS) with ZERO surrounding markup, so existing
// `.container img { … }` CSS keeps applying exactly as before. Authoring stays a
// one-liner: pick a `kind` that matches the image's layout role; set `priority`
// on the page's LCP/hero image only.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  /** Layout role → drives the `sizes` hint and the candidate widths. */
  kind?: 'hero' | 'full' | 'half' | 'card' | 'portrait' | 'bg' | 'thumb';
  /** LCP/hero image only: eager + fetchpriority=high. Everything else stays lazy. */
  priority?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  src,
  alt,
  kind = 'card',
  priority = false,
  class: className,
  ...rest
} = Astro.props as Props;

// `sizes` = the CSS display width of the image at each breakpoint (980px is the
// site's main desktop↔mobile breakpoint). Slightly generous is fine — it only
// nudges which srcset candidate the browser picks; it never affects layout.
const SIZES: Record<NonNullable<Props['kind']>, string> = {
  hero: '100vw',
  bg: '100vw',
  full: '100vw',
  half: '(max-width: 980px) 100vw, 50vw',
  card: '(max-width: 980px) 100vw, 33vw',
  portrait: '(max-width: 980px) 50vw, 25vw',
  thumb: '(max-width: 980px) 180px, 240px',
};

// Candidate widths per role. Clamped to the source's native width below so Astro
// never upscales (no build warnings, no wasted bytes).
const CANDIDATES: Record<NonNullable<Props['kind']>, number[]> = {
  hero: [640, 960, 1280, 1600, 1920],
  bg: [640, 960, 1280, 1600, 1920],
  full: [640, 960, 1280, 1600, 1920],
  half: [480, 768, 1024, 1280],
  card: [400, 640, 768, 960],
  portrait: [320, 480, 640, 800],
  // Small fixed-size cards (e.g. the About constellation, ≤230px). Capped — the
  // native width is intentionally NOT appended, so a 200px slot never pulls a
  // 1400px source.
  thumb: [200, 320, 440],
};

const maxW = src.width;
const base = (CANDIDATES[kind] ?? CANDIDATES.card).filter((w) => w < maxW);
// For thumbnails, cap at the candidate list (don't serve the full-res source);
// otherwise include the native width as the top candidate for retina sharpness.
let widths = kind === 'thumb' ? [...new Set(base)] : [...new Set([...base, maxW])];
if (widths.length === 0) widths = [maxW];
widths.sort((a, b) => a - b);
const sizes = SIZES[kind] ?? SIZES.card;
---

<Image
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  format="webp"
  class={className}
  loading={priority ? 'eager' : 'lazy'}
  decoding="async"
  fetchpriority={priority ? 'high' : 'auto'}
  {...rest}
/>
